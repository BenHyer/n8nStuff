    {
      "parameters": {
        "jsCode": "return $input.all().filter(item => {\n  const data = item.json;\n  \n  // 1. Term Check (1048)\n  const isCorrectTerm = data.enrollment_term_id === 1048;\n  \n  // 2. Active Enrollment Check\n  const isActive = data.enrollments && \n                   data.enrollments.length > 0 && \n                   data.enrollments[0].enrollment_state === 'active';\n  \n  // 3. PUBLISHED CHECK (The fix for the 403 error)\n  // This ensures we don't hit the \"Unpublished\" Cloud App Dev course\n  const isPublished = data.workflow_state === 'available';\n  \n  return isCorrectTerm && isActive && isPublished;\n});"
      },
