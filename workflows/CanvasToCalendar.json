    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nreturn items.map(item => {\n  const data = item.json;\n  const assignmentName = data.name;\n  const courseId = data.course_id;\n  const dueDate = new Date(data.due_at);\n  \n  let schedule = { days: [], start: \"\" };\n  let colorId = \"1\"; // Default (Lavender)\n\n  // 1. SCHEDULES & COLOR MAPPING\n  if (courseId === 1229212 || courseId === 1210923) { \n    // Mobile & Cloud App Dev\n    schedule = { days: [1, 3, 5], start: \"10:30:00\" };\n    colorId = \"3\"; // Purple (Grape)\n  } else if (courseId === 1229214) { \n    // WebTel & Ops\n    schedule = { days: [2, 4], start: \"16:45:00\" }; \n    colorId = \"1\"; // Peacock (Lavender/Pale Blue)\n  } else if (courseId === 1229216) { \n    // Ethics & Craftsmanship\n    schedule = { days: [2, 4], start: \"18:45:00\" }; \n    colorId = \"4\"; // Flamingo\n  } else if (courseId === 1210774) { \n    // Linear Algebra\n    schedule = { days: [1, 3, 5], start: \"08:30:00\" }; \n    colorId = \"5\"; // Banana (Yellow)\n  } else if (courseId === 1211788) { \n    // Personal & Consumer Mgmt.\n    schedule = { days: [2, 4], start: \"08:30:00\" };\n    colorId = \"8\"; // Graphite\n  } else { \n    schedule = { days: [1, 2, 3, 4, 5], start: \"09:00:00\" };\n    colorId = \"1\";\n  }\n\n  // 2. LEAD TIME & TARGET DATE\n  const isProject = /project|exam|paper/i.test(assignmentName);\n  const leadDays = isProject ? 5 : 2;\n  let targetDate = new Date(dueDate);\n  targetDate.setDate(targetDate.getDate() - leadDays);\n\n  // 3. SNAP TO NEAREST CLASS DAY\n  let attempts = 0;\n  while (!schedule.days.includes(targetDate.getDay()) && attempts < 7) {\n    targetDate.setDate(targetDate.getDate() - 1);\n    attempts++;\n  }\n\n  const dateStr = targetDate.toISOString().split('T')[0];\n  \n  // 4. CALCULATE 30-MINUTE DURATION\n  const startTime = new Date(`${dateStr}T${schedule.start}`);\n  const endTime = new Date(startTime.getTime() + 30 * 60000); \n  const endClock = endTime.toTimeString().split(' ')[0];\n\n  return {\n    json: {\n      originalName: assignmentName,\n      colorId: colorId,\n      startDate: `${dateStr}T${schedule.start}-06:00`,\n      endDate: `${dateStr}T${endClock}-06:00`,\n      calendarSearchQuery: assignmentName\n    }\n  };\n});"
      },
