<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RecipeTracker.Pages.NewRecipe"
             Title="New Recipe"
             BackgroundColor="{AppThemeBinding Light=#F8F9FA, Dark=#1A1A1A}">
    
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">
            
            <!-- Header -->
            <Label Text="Create New Recipe" 
                   FontSize="28" 
                   FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light=#2C3E50, Dark=#ECEFF1}"
                   Margin="0,10,0,20"/>

            <!-- Basic Information Section -->
            <Frame Padding="16" 
                   CornerRadius="12" 
                   HasShadow="True"
                   BackgroundColor="{AppThemeBinding Light=White, Dark=#2D2D2D}"
                   BorderColor="Transparent">
                <VerticalStackLayout Spacing="15">
                    <Label Text="Basic Information" 
                           FontSize="18" 
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#34495E, Dark=#ECEFF1}"/>
                    
                    <VerticalStackLayout Spacing="5">
                        <Label Text="Recipe Name" 
                               FontSize="14" 
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#555555, Dark=#B0B0B0}"/>
                        <Entry Text="{Binding Name}" 
                               Placeholder="e.g., Chocolate Chip Cookies"
                               PlaceholderColor="#999999"
                               BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#3A3A3A}"
                               TextColor="{AppThemeBinding Light=Black, Dark=White}"
                               FontSize="16"/>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="5">
                        <Label Text="Description" 
                               FontSize="14" 
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#555555, Dark=#B0B0B0}"/>
                        <Editor Text="{Binding Description}" 
                                Placeholder="Describe your recipe..."
                                PlaceholderColor="#999999"
                                BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#3A3A3A}"
                                TextColor="{AppThemeBinding Light=Black, Dark=White}"
                                FontSize="16"
                                HeightRequest="100"
                                AutoSize="TextChanges"/>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Frame>

            <!-- Ingredients & Instructions Section -->
            <Frame Padding="16" 
                   CornerRadius="12" 
                   HasShadow="True"
                   BackgroundColor="{AppThemeBinding Light=White, Dark=#2D2D2D}"
                   BorderColor="Transparent">
                <VerticalStackLayout Spacing="15">
                    <Label Text="Details" 
                           FontSize="18" 
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#34495E, Dark=#ECEFF1}"/>
                    
                    <VerticalStackLayout Spacing="5">
                        <Label Text="Ingredients" 
                               FontSize="14" 
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#555555, Dark=#B0B0B0}"/>
                        <Editor Text="{Binding Ingredients}" 
                                Placeholder="Enter ingredients separated by commas&#x0a;e.g., 2 cups flour, 1 cup sugar, 3 eggs"
                                PlaceholderColor="#999999"
                                BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#3A3A3A}"
                                TextColor="{AppThemeBinding Light=Black, Dark=White}"
                                FontSize="16"
                                HeightRequest="120"
                                AutoSize="TextChanges"/>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="5">
                        <Label Text="Instructions" 
                               FontSize="14" 
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#555555, Dark=#B0B0B0}"/>
                        <Editor Text="{Binding Instructions}" 
                                Placeholder="Enter cooking steps separated by commas&#x0a;e.g., Preheat oven to 350°F, Mix ingredients, Bake for 30 minutes"
                                PlaceholderColor="#999999"
                                BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#3A3A3A}"
                                TextColor="{AppThemeBinding Light=Black, Dark=White}"
                                FontSize="16"
                                HeightRequest="150"
                                AutoSize="TextChanges"/>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Frame>

            <!-- Time & Servings Section -->
            <Frame Padding="16" 
                   CornerRadius="12" 
                   HasShadow="True"
                   BackgroundColor="{AppThemeBinding Light=White, Dark=#2D2D2D}"
                   BorderColor="Transparent">
                <VerticalStackLayout Spacing="15">
                    <Label Text="Timing and Servings" 
                           FontSize="18" 
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#34495E, Dark=#ECEFF1}"/>
                    
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="15" RowDefinitions="Auto,Auto" RowSpacing="15">
                        
                        <!-- Prep Time -->
                        <VerticalStackLayout Grid.Column="0" Grid.Row="0" Spacing="5">
                            <Label Text="Prep Time" 
                                   FontSize="14" 
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#555555, Dark=#B0B0B0}"/>
                            <HorizontalStackLayout Spacing="5">
                                <Entry Text="{Binding PreparationTime}" 
                                       Keyboard="Numeric"
                                       Placeholder="30"
                                       PlaceholderColor="#999999"
                                       BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#3A3A3A}"
                                       TextColor="{AppThemeBinding Light=Black, Dark=White}"
                                       FontSize="16"
                                       HorizontalOptions="FillAndExpand"/>
                                <Label Text="min" 
                                       VerticalOptions="Center"
                                       TextColor="{AppThemeBinding Light=#777777, Dark=#999999}"
                                       FontSize="14"/>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>

                        <!-- Cooking Time -->
                        <VerticalStackLayout Grid.Column="1" Grid.Row="0" Spacing="5">
                            <Label Text="Cook Time" 
                                   FontSize="14" 
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#555555, Dark=#B0B0B0}"/>
                            <HorizontalStackLayout Spacing="5">
                                <Entry Text="{Binding CookingTime}" 
                                       Keyboard="Numeric"
                                       Placeholder="45"
                                       PlaceholderColor="#999999"
                                       BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#3A3A3A}"
                                       TextColor="{AppThemeBinding Light=Black, Dark=White}"
                                       FontSize="16"
                                       HorizontalOptions="FillAndExpand"/>
                                <Label Text="min" 
                                       VerticalOptions="Center"
                                       TextColor="{AppThemeBinding Light=#777777, Dark=#999999}"
                                       FontSize="14"/>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>

                        <!-- Servings -->
                        <VerticalStackLayout Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="2" Spacing="5">
                            <Label Text="Servings" 
                                   FontSize="14" 
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#555555, Dark=#B0B0B0}"/>
                            <Entry Text="{Binding Servings}" 
                                   Keyboard="Numeric"
                                   Placeholder="4"
                                   PlaceholderColor="#999999"
                                   BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#3A3A3A}"
                                   TextColor="{AppThemeBinding Light=Black, Dark=White}"
                                   FontSize="16"
                                   WidthRequest="150"
                                   HorizontalOptions="Start"/>
                        </VerticalStackLayout>
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <!-- Save Button -->
            <Button Text="Save Recipe" 
                    Command="{Binding SaveRecipeCommand}"
                    FontSize="18"
                    FontAttributes="Bold"
                    BackgroundColor="#27AE60"
                    TextColor="White"
                    CornerRadius="12"
                    HeightRequest="55"
                    Margin="0,10,0,20"/>
            
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>